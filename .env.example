# ── Required ───────────────────────────────────────────────────
# ENTSO-E API — register free at transparency.entsoe.eu
ENTSOE_API_KEY=your_entsoe_api_key_here

# ── MLflow (optional — defaults to local ./mlruns folder) ──────
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Notifications (optional) ───────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
ALERT_EMAIL=your@email.com
SMTP_HOST=smtp.gmail.com
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# ── Production Deployment (for GitHub Actions CI/CD) ───────────
SERVER_HOST=your.server.ip.address
SERVER_USER=ubuntu
SSH_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----...

# ── DVC Remote Storage (optional — for team data sharing) ──────
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
